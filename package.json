{
  "name": "ts-config-validator",
  "version": "0.1.0",
  "description": "Validate YAML/JSON config files against TypeScript interfaces with JSDoc constraints. No code generation — constraints live in JSDoc comments, validation runs at test time via the TS compiler API.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "ts-config-validator": "dist/cli.js"
  },
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./parsers/yaml": {
      "require": "./dist/parsers/yaml.js",
      "types": "./dist/parsers/yaml.d.ts"
    },
    "./parsers/json": {
      "require": "./dist/parsers/json.js",
      "types": "./dist/parsers/json.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src tests --ext .ts",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "keywords": [
    "typescript",
    "yaml",
    "json",
    "validation",
    "config",
    "jsdoc",
    "schema",
    "jest"
  ],
  "author": "Sámuel Léránt (https://github.com/samu112)",
  "license": "MIT",
  "peerDependencies": {
    "typescript": ">=4.7.0"
  },
  "peerDependenciesMeta": {
    "yaml": {
      "optional": true
    }
  },
  "dependencies": {
    "commander": "^12.0.0",
    "fast-glob": "^3.3.0"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0",
    "yaml": "^2.4.0"
  }
}
